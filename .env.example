# AI Recruiter v2.0 — Environment Variables
# ─────────────────────────────────────────────────────────────
# STEP 1: Get your FREE Groq API key at: https://console.groq.com
# STEP 2: Paste it below, replacing the placeholder.
# STEP 3: NEVER commit this file to git. It's in .gitignore.
# ─────────────────────────────────────────────────────────────

GROQ_API_KEY=gsk_your_free_groq_api_key_here

# ── Model Configuration ───────────────────────────────────────
# llama-3.1-8b-instant  → Fast (~1-2s), great for hackathon latency
# llama-3.3-70b-versatile → Slower (~4-6s), best reasoning quality
GROQ_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.05
LLM_MAX_TOKENS=1200

# ── Ranking Configuration ─────────────────────────────────────
# Path to your candidates JSON file (relative to project root)
CANDIDATES_FILE=data/sample_candidates.json
# Number of candidates in the shortlist
SHORTLIST_SIZE=10
